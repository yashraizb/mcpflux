# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── LLM Provider (default: anthropic) ─────────────────────────────────────────
# LLM_PROVIDER=anthropic          # "anthropic" | "openai" | "google"
# MODEL_NAME=claude-haiku-4-5     # model name for the chosen provider
# OPENAI_API_KEY=your-openai-api-key-here

# ── LangSmith tracing (optional, free tier at smith.langchain.com) ────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key-here
# LANGSMITH_PROJECT=mcpflux

# ── Observability storage ─────────────────────────────────────────────────────
# EVENTS_LOG_PATH=~/.mcpflux/events.jsonl   # JSONL event log (default)
# METRICS_DB_PATH=~/.mcpflux/metrics.db     # SQLite metrics DB (default)
